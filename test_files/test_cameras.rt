# --- LUMIÈRES ---
A 0.2 255,255,255
L 0,60,20 0.8 255,255,255

# --- CAMÉRAS (Le test) ---

# 1. Vue de Gauche (Profil) : On doit voir le cylindre comme un rectangle bleu
C -60,10,0 1,0,0 70

# 2. Vue de Face (Axe Z) : On doit voir le disque du cylindre (rond bleu)
C 0,10,-60 0,0,1 70

# 3. Vue de Haut (Ciel) : On doit voir la scène d'en haut (le sol rose remplit tout)
# Note: petit décalage x=0.01 pour éviter le bug du vecteur (0,-1,0) // vecteur up
C 0.01,80,0 0,-1,0 70

# --- OBJETS ---

# Sol (Rose)
pl 0,0,0 0,1,0 255,0,225

# Cylindre (Bleu) :: Couché sur l'axe Z
# x=0, y=10 (posé au sol), z=0, axe=0,0,1
cy 0,10,0 0,0,1 20 30 0,0,255

# Sphère (Rouge) :: Juste à côté pour repère
sp 20,10,0 10 255,0,0