#* ---------------- SCENE DE TEST : TRIANGLES & OPTIMISATION ----------------
#* A, R, C, L : Configuration identique pour garder vos repères
R   1920 1080
A   0.1   255,255,255

#* Caméra reculée et légèrement surélevée pour voir les objets 3D
C   0,5,-25    0,-0.1,1    50

#* Lumières : Une principale et des lumières colorées pour les ombres
L   0,10,-10   0.6         255,255,255
L   -10,10,0   0.3         255,0,100
L   10,10,0    0.3         0,100,255

#* Sol et Plafond (Plan)
pl  0,0,0      0,1,0       50,50,50
pl  0,20,0     0,-1,0      30,30,30

#* ---------------- OBJETS TRIANGLES (MESHES) ----------------

#* --- 1. OCTAÈDRE CENTRAL (Le "Diamant") ---
#* Un volume fermé de 8 triangles.
#* Centre ~ (0, 5, 0). Vertices: Top(0,8,0), Bot(0,2,0), Front(0,5,3), Back(0,5,-3), Left(-3,5,0), Right(3,5,0)

#* Face Haut-Avant-Droite (Rougeâtre)
tri  0,8,0    3,5,0    0,5,3      220,20,60
#* Face Haut-Avant-Gauche (Verdâtre)
tri  0,8,0    0,5,3   -3,5,0      34,139,34
#* Face Haut-Arrière-Gauche (Bleuâtre)
tri  0,8,0   -3,5,0    0,5,-3     65,105,225
#* Face Haut-Arrière-Droite (Jaunâtre)
tri  0,8,0    0,5,-3   3,5,0      255,215,0

#* Face Bas-Avant-Droite (Cyan)
tri  0,2,0    0,5,3    3,5,0      0,255,255
#* Face Bas-Avant-Gauche (Magenta)
tri  0,2,0   -3,5,0    0,5,3      255,0,255
#* Face Bas-Arrière-Gauche (Gris)
tri  0,2,0    0,5,-3  -3,5,0      128,128,128
#* Face Bas-Arrière-Droite (Blanc)
tri  0,2,0    3,5,0    0,5,-3     200,200,200


#* --- 2. PYRAMIDE GAUCHE (Tétraèdre) ---
#* Positionnée à X = -10. Pointe vers le haut.
#* Sommet(-10, 8, 0), Base1(-13, 0, 3), Base2(-7, 0, 3), Base3(-10, 0, -3)

#* Face Avant (Orange)
tri  -10,8,0   -13,0,3   -7,0,3     255,140,0
#* Face Droite Arrière (Violet)
tri  -10,8,0   -7,0,3    -10,0,-3   138,43,226
#* Face Gauche Arrière (Lime)
tri  -10,8,0   -10,0,-3  -13,0,3    50,205,50
#* Base (regarde vers le sol - souvent invisible sauf reflets, ici bleu sombre)
tri  -13,0,3   -10,0,-3  -7,0,3     0,0,139


#* --- 3. CUBE DROITE (12 Triangles) ---
#* Positionné à X = 10. Cube de taille 4.
#* Coins avant: (8,0,2) à (12,4,2). Coins arrière: (8,0,-2) à (12,4,-2)

#* Face AVANT (Z=2) - Rouge
tri  8,0,2     12,0,2    8,4,2      255,0,0
tri  12,0,2    12,4,2    8,4,2      200,0,0

#* Face ARRIÈRE (Z=-2) - Vert (Visible si on tourne la caméra)
tri  12,0,-2   8,0,-2    12,4,-2    0,255,0
tri  8,0,-2    8,4,-2    12,4,-2    0,200,0

#* Face GAUCHE (X=8) - Bleu
tri  8,0,-2    8,0,2     8,4,-2     0,0,255
tri  8,0,2     8,4,2     8,4,-2     0,0,200

#* Face DROITE (X=12) - Jaune
tri  12,0,2    12,0,-2   12,4,2     255,255,0
tri  12,0,-2   12,4,-2   12,4,2     200,200,0

#* Face HAUT (Y=4) - Cyan
tri  8,4,2     12,4,2    8,4,-2     0,255,255
tri  12,4,2    12,4,-2   8,4,-2     0,200,200

#* Face BAS (Y=0) - Magenta
tri  8,0,-2    12,0,-2   8,0,2      255,0,255
tri  12,0,-2   12,0,2    8,0,2      200,0,200

#* ---------------- STRESS TEST ARRIÈRE PLAN ----------------
#* Quelques grands triangles au fond pour forcer le calcul de profondeur (Z)

tri  -20,0,20   0,20,20   20,0,20   50,50,50
tri  -15,5,18   0,25,18   15,5,18   80,80,80