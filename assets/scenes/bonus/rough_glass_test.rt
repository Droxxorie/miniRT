rec 0,11.9,10   0,-1,0    8.0    5.0    255,255,255 -usemtl light
# SUN	    1,-1,1                         0.5    255,244,214

rec 0,-2.44,0    0,1,0     80.0   80.0   255,255,255 -usemtl BlackChecker
rec 0,12,0    0,1,0     80.0   80.0   255,255,255 -usemtl floor
