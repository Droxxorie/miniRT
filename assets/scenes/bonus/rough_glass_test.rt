C 4,-0.5,1.5 0,-0.05,1 55 #800
C 0,-0.5,1.5 0,-0.05,1 55 #900
C -4,-0.5,1.5 0,-0.05,1 55 #950
C -8,-0.5,1.5 0,-0.05,1 55 #1000

R 720 720
# R 360 360
# R 1280 240

SAMPLES 10
mtllib assets/materials/rough_glass.mtl

# FILTER SOBEL
# FILTER BNW
# FILTER GAUSSIAN 10.0
# FILTER SEPIA
# FILTER SHARPEN 1.0
# FILTER CONTRAST 1.1
