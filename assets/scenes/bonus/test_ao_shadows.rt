# --- LUMIERE AMBIANTE ---
# Assez forte (0.4) pour qu'on voit bien les zones d'ombre de l'AO
A 0.4 255,255,255
R 1920 1080
# --- CAMERA ---
# Positionnée en hauteur, regardant vers le bas pour voir le sol
C 0,5,-12 0,-0.3,1.0 70

# --- LUMIERE PONCTUELLE ---
# Décalée pour créer des ombres portées, mais pas trop forte
L 5,10,-5 0.8 255,255,255

# ============================================================
# ZONE 1 : RT AO (GAUCHE)
# Test : Le contact entre la sphère et le sol doit être sombre.
# ============================================================

# Sol (Gris pour bien voir les ombres noires)
pl 0,0,0 0,1,0 200,200,200 

# Sphère rouge posée sur le sol
# Vérifie le dégradé sombre à la base de la sphère
sp -4,1,0 2.0 200,50,50

# Un Cylindre vert juste à côté pour tester l'occlusion entre deux objets RT
cy -6,1,1 0,1,0 1.0 2.0 50,200,50


# ============================================================
# ZONE 2 : SDF AO "SELF-SHADOWING" (CENTRE/DROITE)
# Test : Les trous profonds doivent être noirs (SDF Cone Tracing)
# ============================================================

# Mandelbulb (Si ton parser le gère)
# Il doit flotter au dessus du sol.
# Regarde SOUS le mandelbulb : le sol doit être assombri (RT AO lancé sur SDF)
# Regarde DANS le mandelbulb : les creux doivent être noirs (SDF AO)
# (Adapte les paramètres à ton parser : pos, scale, power...)
mandelbox  0,3,0  0,1,0  1.0  -2.09  0.7  1.0  1.0  255,200,100


# Menger Sponge (Droite)
# C'est le test ultime pour l'AO SDF. L'intérieur doit être très sombre.
# (Adapte les paramètres : pos, scale_factor...)
menger_sponge    4,1.5,0  0,1,0  1.0  3.0  200,200,200


# ============================================================
# ZONE 3 : JULIA (FOND)
# Test : Translucidité/Finesse
# ============================================================

# Un Julia flottant pour voir si l'AO réagit bien aux formes courbes
julia_set  0,3,-5  0,1,0  1.0  -0.2,0.6,0.2,0.1  FALSE  FALSE  FALSE  100,100,255
