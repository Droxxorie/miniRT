# ============================================================
# LABORATOIRE DE TEST PBR & VOLUMETRIQUE
# ============================================================
# R 1920 1080
# R   160 90
A   0.05            255,255,255
C   0,8,22          0,-0.3,-1      40
C   0, 3.5,7        0,-0.3,-1 40
C   6,2,0           0,0,-1	   60
L   -10,15,10       200            255,255,255
L   10,5,10         50            100,100,255

# 4. FICHIER MATERIAUX
mtllib assets/materials/materials_test.mtl

# ============================================================
# GEOMETRIE
# ============================================================

pl  0,0,0           0,1,0          200,200,200      -usemtl RoughPlaster
pl  0,0,-10         0,0,1          150,50,50        -usemtl RedMatte

# Sphère : (Oren-Nayar)
sp  -6,2,0          2.0            180,0,0          -usemtl RedVelvet
cy  -6,2,5          0,1,0          1.5  4.0         0,0,200          -usemtl BluePlasticPhong

# --- CENTRE : (Cook-Torrance) ---
sp  -1,2,-2         2.0            0,0,0            -usemtl PBR_Gold
sp  2,2,2           2.0            0,0,0            -usemtl PBR_Silver

# --- DROITE : TRANSPARENCE & BEER-LAMBERT ---

# Sphère : Verre "Absinthe" (Beer-Lambert)
# Le centre doit être vert foncé, les bords clairs/transparents
sp  6,2,-2          2.0            255,255,255      -usemtl ThickGreenGlass
sp  6,2,-10    12.0    0,0,0         -usemtl SuperNeon
# Cone : Rubis (Beer-Lambert)
# Test de réfraction complexe sur une forme conique
con  6,0,5           0,1,0          2.0  4.0         255,255,255      -usemtl DeepRuby

# --- LE TEST HDR (High Dynamic Range) ---

# Petite sphère flottante très lumineuse (Ke 50)
# Si le Tone Mapping marche, elle doit être blanche éclatante sans "clipper" moche
# Elle devrait éclairer le sol autour d'elle si tu as la Global Illumination (Path Tracing)
# Sinon elle sera juste un point très blanc.
sp  0,6,5           1.0            0,0,0            -usemtl SuperNeon